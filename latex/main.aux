\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces DCCE architecture. Two encoders process the rhythm (ICI, blue) and spectral (mel, orange) channels independently. Their 64-d embeddings are concatenated and fused into joint embedding $\mathbf  {z}$. Three objectives train the model jointly: NT-Xent contrastive loss on $\mathbf  {z}$, coda-type CE on $\mathbf  {r}_\text  {emb}$, and individual-ID CE on $\mathbf  {s}_\text  {emb}$.}}{3}{figure.caption.5}\protected@file@percent }
\newlabel{fig:architecture}{{3}{3}{DCCE architecture. Two encoders process the rhythm (ICI, blue) and spectral (mel, orange) channels independently. Their 64-d embeddings are concatenated and fused into joint embedding $\mathbf {z}$. Three objectives train the model jointly: NT-Xent contrastive loss on $\mathbf {z}$, coda-type CE on $\mathbf {r}_\text {emb}$, and individual-ID CE on $\mathbf {s}_\text {emb}$}{figure.caption.5}{}}
\newlabel{fig:architecture@cref}{{[figure][3][]3}{[1][3][]3}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Training Objective}{3}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cross-channel positive pair construction. Spectral context is swapped across two same-unit codas, forcing $\mathbf  {z}$ to be invariant to which specific coda provided spectral texture, as long as speaker identity (social unit) is shared.}}{3}{figure.caption.6}\protected@file@percent }
\newlabel{fig:crosspairs}{{4}{3}{Cross-channel positive pair construction. Spectral context is swapped across two same-unit codas, forcing $\mathbf {z}$ to be invariant to which specific coda provided spectral texture, as long as speaker identity (social unit) is shared}{figure.caption.6}{}}
\newlabel{fig:crosspairs@cref}{{[figure][4][]4}{[1][3][]3}{}{}{}}
