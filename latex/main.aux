\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Recording-year confound analysis. Left: contingency table of unit $\times $ recording year --- Unit~A was recorded only in 2005/2009, Unit~D only in 2008/2010. Right: year-F1 and unit-F1 co-vary across layers (Spearman $\rho =0.63$, $p=0.003$).}}{4}{figure.caption.9}\protected@file@percent }
\newlabel{fig:confound}{{6}{4}{Recording-year confound analysis. Left: contingency table of unit $\times $ recording year --- Unit~A was recorded only in 2005/2009, Unit~D only in 2008/2010. Right: year-F1 and unit-F1 co-vary across layers (Spearman $\rho =0.63$, $p=0.003$)}{figure.caption.9}{}}
\newlabel{fig:confound@cref}{{[figure][6][]6}{[1][4][]4}{}{}{}}
